{:source-paths ["src"]
 :dependencies [[reagent "2.0.1"]]
 :dev-http {8080 "resources/public"}
 :builds {:frontend {:target :browser
                     :output-dir "resources/public/js"
                     :asset-path "/js"
                     :modules {:main {:init-fn habits.frontend.core/init
                                      :entries [habits.frontend.core]}}
                     :devtools {:after-load habits.frontend.core/init
                                :before-load prune/disable-cache}}}}